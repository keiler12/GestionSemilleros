@model IEnumerable<GestionSemilleros.Models.Entidades.Semillero>
@{
    ViewBag.Title = "Semilleros";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="filtros-panel">
    <span class="filtros-label">Consultar por parámetros</span>
    @using (Html.BeginForm("Semilleros", "Administrador", FormMethod.Get))
    {
        <div class="filtros-fila">
            <span style="font-size:13px; font-weight:500; color:#374151; white-space:nowrap;">Selecciona la opción</span>
            <select name="filtroCampo" class="filtro-select" onchange="this.form.submit()">
                <option value="">Selecciona...</option>
                <option value="Nombre" @(ViewBag.FiltroCampo == "Nombre" ? "selected" : "")>Nombre</option>
                <option value="Linea" @(ViewBag.FiltroCampo == "Linea" ? "selected" : "")>Línea</option>
                <option value="Enfoque" @(ViewBag.FiltroCampo == "Enfoque" ? "selected" : "")>Enfoque</option>
            </select>
            <select name="filtroValor" class="filtro-select">
                <option value="">Todos</option>
                @foreach (var valor in ViewBag.ValoresFiltro as List<string>)
                {
                    <option value="@valor" @(ViewBag.FiltroValor == valor ? "selected" : "")>@valor</option>
                }
            </select>
            <button type="submit" class="btn-buscar">
                <i class="bi bi-search"></i> Buscar
            </button>
            <a href="@Url.Action("Semilleros", "Administrador")" class="btn-limpiar">
                <i class="bi bi-eraser"></i> Limpiar

            </a>
        </div>
    }
</div>

<div class="encabezado-modulo">
    <h4>Gestionar Semilleros</h4>
    <div style="display:flex; gap:8px;">
        <button class="btn-registrar" data-bs-toggle="modal" data-bs-target="#modalRegistrar">
            <i class="bi bi-plus-lg"></i> Registrar
        </button>
        <a href="@Url.Action("ReporteSemilleros", "Administrador")" target="_blank" class="btn-registrar" style="background:#E24B4A;">
            <i class="bi bi-file-pdf-fill"></i> Reporte PDF
        </a>
    </div>
</div>

<table>
    <thead>
        <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Línea</th>
            <th>Enfoque</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var semillero in Model)
        {
            <tr>
                <td>@semillero.IdSemillero</td>
                <td>@semillero.NombreSemillero</td>
                <td>@semillero.LineaSemillero</td>
                <td>@semillero.EnfoqueSemillero</td>
                <td class="acciones">
                    <button class="btn-editar"
                            data-bs-toggle="modal"
                            data-bs-target="#modalEditar"
                            data-id="@semillero.IdSemillero"
                            data-nombre="@semillero.NombreSemillero"
                            data-linea="@semillero.LineaSemillero"
                            data-enfoque="@semillero.EnfoqueSemillero">
                        <i class="bi bi-pencil-fill"></i> Editar
                    </button>
                    @using (Html.BeginForm("EliminarSemillero", "Administrador", FormMethod.Post, new { style = "display:inline" }))
                    {
                        @Html.Hidden("id", semillero.IdSemillero)
                        <button type="submit" class="btn-eliminar"
                                onclick="return confirm('¿Estás seguro de eliminar este semillero?')">
                            <i class="bi bi-trash-fill"></i> Eliminar
                        </button>
                    }

                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Modal Registrar -->
<div class="modal fade" id="modalRegistrar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Registrar semillero</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            @using (Html.BeginForm("RegistrarSemillero", "Administrador", FormMethod.Post))
            {
                <div class="modal-body">
                    <div class="campo-form">
                        <label>Nombre del semillero</label>
                        <input type="text" name="NombreSemillero" class="form-control" required />
                    </div>
                    <div class="campo-form">
                        <label>Línea de investigación</label>
                        <input type="text" name="LineaSemillero" class="form-control" required />
                    </div>
                    <div class="campo-form">
                        <label>Enfoque</label>
                        <input type="text" name="EnfoqueSemillero" class="form-control" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-cancelar" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn-guardar">Guardar</button>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal Editar -->
<div class="modal fade" id="modalEditar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Editar semillero</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            @using (Html.BeginForm("ModificarSemillero", "Administrador", FormMethod.Post))
            {
                <div class="modal-body">
                    <input type="hidden" name="IdSemillero" id="editId" />
                    <div class="campo-form">
                        <label>Nombre del semillero</label>
                        <input type="text" name="NombreSemillero" id="editNombre" class="form-control" required />
                    </div>
                    <div class="campo-form">
                        <label>Línea de investigación</label>
                        <input type="text" name="LineaSemillero" id="editLinea" class="form-control" required />
                    </div>
                    <div class="campo-form">
                        <label>Enfoque</label>
                        <input type="text" name="EnfoqueSemillero" id="editEnfoque" class="form-control" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-cancelar" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn-guardar">Guardar</button>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('modalEditar').addEventListener('show.bs.modal', function (event) {
            var boton = event.relatedTarget;
            document.getElementById('editId').value = boton.getAttribute('data-id');
            document.getElementById('editNombre').value = boton.getAttribute('data-nombre');
            document.getElementById('editLinea').value = boton.getAttribute('data-linea');
            document.getElementById('editEnfoque').value = boton.getAttribute('data-enfoque');
        });
    </script>
}