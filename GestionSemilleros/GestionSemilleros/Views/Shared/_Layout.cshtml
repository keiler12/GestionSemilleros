<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title — Gestión de Semilleros</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="@Url.Content("~/Content/css/admin.css")" rel="stylesheet" />
</head>
<body>
    <div class="contenedor-principal">
        <div class="sidebar">
            <div class="sidebar-encabezado">
                <div class="rol">Administrador</div>
                <div class="bienvenida">¿Qué gestionamos hoy?</div>
            </div>

            <div class="menu-items">
                <a href="@Url.Action("Usuarios", "Administrador")" class="menu-item @(ViewBag.MenuActivo == "Usuarios" ? "activo" : "")">
                    <i class="bi bi-people-fill"></i> Usuarios
                </a>
                <a href="@Url.Action("Semilleros", "Administrador")" class="menu-item @(ViewBag.MenuActivo == "Semilleros" ? "activo" : "")">
                    <i class="bi bi-flower1"></i> Semillero
                </a>
                <a href="@Url.Action("Proyectos", "Administrador")" class="menu-item @(ViewBag.MenuActivo == "Proyectos" ? "activo" : "")">
                    <i class="bi bi-clipboard-check-fill"></i> Proyectos
                </a>
                <a href="@Url.Action("Eventos", "Administrador")" class="menu-item @(ViewBag.MenuActivo == "Eventos" ? "activo" : "")">
                    <i class="bi bi-calendar-event-fill"></i> Eventos
                </a>
                <a href="@Url.Action("Reportes", "Administrador")" class="menu-item @(ViewBag.MenuActivo == "Reportes" ? "activo" : "")">
                    <i class="bi bi-file-earmark-text-fill"></i> Reportes
                </a>
                <a href="@Url.Action("Patrocinadores", "Administrador")" class="menu-item @(ViewBag.MenuActivo == "Patrocinadores" ? "activo" : "")">
                    <i class="bi bi-heart-fill"></i> Patrocinadores
                </a>
            </div>

            <a href="@Url.Action("CerrarSesion", "Login")" class="cerrar-sesion">
                <i class="bi bi-box-arrow-left"></i> Cerrar sesión
            </a>
        </div>

        <div class="area-contenido">
            @RenderBody()
        </div>
    </div>
</body>
</html>