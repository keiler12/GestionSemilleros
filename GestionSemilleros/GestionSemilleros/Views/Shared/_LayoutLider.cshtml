<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title — Gestión de Semilleros</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="@Url.Content("~/Content/css/admin.css")" rel="stylesheet" />
</head>
<body>
    <div class="contenedor-principal">
        <div class="sidebar">
            <div class="sidebar-encabezado">
                <div class="rol">Líder</div>
                <div class="bienvenida">¿Qué gestionamos hoy?</div>
            </div>

            <div class="menu-items">
                <a href="@Url.Action("Index", "Lider")" class="menu-item @(ViewBag.MenuActivo == "Inicio" ? "activo" : "")">
                    <i class="bi bi-house-fill"></i> Inicio
                </a>
                <a href="@Url.Action("MiSemillero", "Lider")" class="menu-item @(ViewBag.MenuActivo == "MiSemillero" ? "activo" : "")">
                    <i class="bi bi-flower1"></i> Mi Semillero
                </a>
                <a href="@Url.Action("Investigadores", "Lider")" class="menu-item @(ViewBag.MenuActivo == "Investigadores" ? "activo" : "")">
                    <i class="bi bi-people-fill"></i> Investigadores
                </a>
                <a href="@Url.Action("Proyectos", "Lider")" class="menu-item @(ViewBag.MenuActivo == "Proyectos" ? "activo" : "")">
                    <i class="bi bi-clipboard-check-fill"></i> Proyectos
                </a>
                <a href="@Url.Action("Reuniones", "Lider")" class="menu-item @(ViewBag.MenuActivo == "Reuniones" ? "activo" : "")">
                    <i class="bi bi-calendar-check-fill"></i> Reuniones
                </a>
            </div>

            <a href="@Url.Action("CerrarSesion", "Login")" class="cerrar-sesion">
                <i class="bi bi-box-arrow-left"></i> Cerrar sesión
            </a>
        </div>

        <div class="area-contenido">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>